generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  firstname String
  lastname  String
  username  String   @unique
  password  String
  role      String   @default("staff")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id          Int          @id @default(autoincrement())
  firstname   String
  lastname    String
  age         Int
  address     String?
  phone       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  birthDate   DateTime?
  gender      String?
  parentName  String?
  image       String?
  assessments Assessment[]
}

model Assessment {
  id               Int           @id @default(autoincrement())
  assessmentNumber String        @unique
  studentId        Int
  assessmentDate   DateTime      @default(now())
  overallScore     Float?
  overallLevel     String?
  status           String        @default("draft")
  teacherNotes     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  recommendation   String?
  summary          String?
  student          Student       @relation(fields: [studentId], references: [id])
  domainScores     DomainScore[]
}

model DomainScore {
  id              Int             @id @default(autoincrement())
  assessmentId    Int
  domain          String
  score           Float?
  level           String?
  observations    String?
  questionGroupId Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  assessment      Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionGroup   QuestionGroup?  @relation(fields: [questionGroupId], references: [id])
  questionScores  QuestionScore[]
}

model QuestionScore {
  id            Int         @id @default(autoincrement())
  domainScoreId Int
  questionText  String
  score         Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  comment       String?
  domainScore   DomainScore @relation(fields: [domainScoreId], references: [id], onDelete: Cascade)
}

model QuestionGroup {
  id           Int           @id @default(autoincrement())
  title        String
  description  String?
  domain       String
  status       String        @default("active")
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  domainScores DomainScore[]
  questions    Question[]
}

model Question {
  id              Int           @id @default(autoincrement())
  questionGroupId Int
  questionText    String
  helperText      String?
  scoreType       String        @default("numeric")
  minScore        Float         @default(1.0)
  maxScore        Float         @default(3.0)
  step            Float         @default(0.5)
  required        Boolean       @default(false)
  placeholder     String?
  status          String        @default("active")
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  description     String?
  questionGroup   QuestionGroup @relation(fields: [questionGroupId], references: [id], onDelete: Cascade)
}
